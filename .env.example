# Elasticsearch version
STACK_VERSION=7.17.29

# Cluster identity
CLIENT_DOMAIN=lab.esiem.io
CLUSTER_NAME=esiem_core-cluster
SWARM_HOSTNAME=MiniServer01

# Elasticsearch data paths
ES01_DATA=/ESIEM/Data/es01
ES02_DATA=/ESIEM/Data/es02
ES03_DATA=/ESIEM/Data/es03
ES_BACKUP=/ESIEM/Data/backups

# Certificates
CERTS_DIR=/ESIEM/Certs/lab.esiem.io

# Networking / ports
ES_PORT=9200
TZ=America/Edmonton

# Security
ELASTIC_PASSWORD=change-me
LICENSE=basic

# JVM heap
ES01_JAVA_OPTS="-Xms1g -Xmx1g"
ES02_JAVA_OPTS="-Xms2g -Xmx2g"
ES03_JAVA_OPTS="-Xms2g -Xmx2g"

# Container memory limits (bytes)
ES01_MEM_LIMIT=2147483648
ES02_MEM_LIMIT=4294967296
ES03_MEM_LIMIT=4294967296