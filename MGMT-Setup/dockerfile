FROM python:3.11-slim

ARG PYTHON_ELASTICSEARCH_VERSION

WORKDIR /app

RUN apt-get update && \
    apt-get install -y curl jq && \
    rm -rf /var/lib/apt/lists/*

RUN test -n "$PYTHON_ELASTICSEARCH_VERSION" && \
    pip install --no-cache-dir elasticsearch==${PYTHON_ELASTICSEARCH_VERSION}

COPY vault-entrypoint.sh /usr/local/bin/vault-entrypoint.sh
COPY setup.py /app/setup.py
COPY Setup_Accounts.py /app/Setup_Accounts.py
COPY Setup_SchedulerIndex_Tasks.py /app/Setup_SchedulerIndex_Tasks.py

RUN chmod +x /usr/local/bin/vault-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/vault-entrypoint.sh"]